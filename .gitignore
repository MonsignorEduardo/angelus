# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Temporary files, for example, from tests.
/tmp/

# Local OS metadata.
.DS_Store
**/.DS_Store

# Local editor settings.
/.zed/

# Runtime JPL/NAIF kernels are downloaded explicitly and are not source assets.
/priv/kernels/

# Native build scratch and compiled artefacts.
/priv/angelus_spice.so
/priv/angelus_spice.dylib
/priv/angelus_spice.dll
/native/**/*.o
/native/**/*.a
/native/**/*.so
/native/**/*.dylib
/native/**/*.dll

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
angelus-*.tar

# Native C dependencies (downloaded at build time)
native/libs/

# Meson build dirs and wrap checkouts
native/build/
native/subprojects/cspice/

# Native build objects
native/spice_worker/build/

# Compiled spice_worker binary (managed by elixir_make)
/priv/spice_worker
/priv/plts/
